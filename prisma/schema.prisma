generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// Seed configuration
// Run: npx prisma db seed

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("ADMIN")
  active        Boolean   @default(true)
  photoUrl      String?   @db.Text
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  teacher          Teacher?
  auditLogs        AuditLog[]
  sentCommunications Communication[] @relation("sentCommunications")
  sentMessages     Message[]
  uploadedDocuments Document[] @relation("uploadedDocuments")

  @@map("users")
}

model Student {
  id                    String         @id @default(cuid())
  photoUrl              String?   @db.Text
  name                  String
  artisticName          String?
  cpf                   String         @unique
  rg                    String?
  birthDate             DateTime
  gender                String?
  phone                 String?
  whatsapp              String?
  email                 String?
  street                String?
  number                String?
  complement            String?
  neighborhood          String?
  city                  String?
  state                 String?
  zipCode               String?
  financialResponsible  String?
  legalResponsible      String?
  notes                 String?   @db.Text
  status                String         @default("ACTIVE")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  enrollments           Enrollment[]
  attendances           Attendance[]
  documents             Document[]

  @@map("students")
}

model Teacher {
  id             String        @id @default(cuid())
  userId         String?       @unique
  photoUrl       String?   @db.Text
  name           String
  cpf            String        @unique
  phone          String?
  email          String?
  specialty      String?
  curriculum     String?   @db.Text
  availability   String?
  hourlyRate     Float         @default(0)
  notes          String?   @db.Text
  status         String        @default("ACTIVE")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User?         @relation(fields: [userId], references: [id])
  classes        Class[]

  @@map("teachers")
}

model Course {
  id                  String       @id @default(cuid())
  name                String
  description         String?   @db.Text
  workload            Int          @default(0)
  enrollmentFee       Float        @default(0)
  monthlyFee          Float        @default(0)
  minAge              Int?
  maxAge              Int?
  maxStudents         Int          @default(30)
  status              String       @default("ACTIVE")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  classes             Class[]

  @@map("courses")
}

model Class {
  id              String      @id @default(cuid())
  courseId         String
  teacherId       String?
  room            String?
  weekDays        String   @db.Text      // JSON array of weekdays: ["MONDAY","WEDNESDAY","FRIDAY"]
  startTime       String      // HH:mm format
  endTime         String      // HH:mm format
  period          String?     // Morning, Afternoon, Evening
  maxStudents     Int         @default(20)
  status          String      @default("ACTIVE")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  course          Course      @relation(fields: [courseId], references: [id])
  teacher         Teacher?    @relation(fields: [teacherId], references: [id])
  enrollments     Enrollment[]
  attendances     Attendance[]
  events          Event[]

  @@map("classes")
}

model Enrollment {
  id              String           @id @default(cuid())
  studentId       String
  classId         String
  monthlyFee      Float            @default(0)
  contractDate    DateTime         @default(now())
  startDate       DateTime         @default(now())
  endDate         DateTime?
  notes           String?   @db.Text
  status          String           @default("ACTIVE")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  student         Student          @relation(fields: [studentId], references: [id])
  class           Class            @relation(fields: [classId], references: [id])
  payments        Payment[]

  @@map("enrollments")
}

model Attendance {
  id              String           @id @default(cuid())
  studentId       String
  classId         String
  date            DateTime
  status          String           @default("PRESENT")
  content         String?   @db.Text
  notes           String?   @db.Text
  recordedBy      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  student         Student          @relation(fields: [studentId], references: [id])
  class           Class            @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@map("attendances")
}

model Payment {
  id              String        @id @default(cuid())
  enrollmentId    String
  dueDate         DateTime
  paidDate        DateTime?
  amount          Float         @default(0)
  status          String        @default("PENDING")
  method          String?
  notes           String?   @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  enrollment      Enrollment    @relation(fields: [enrollmentId], references: [id])

  @@map("payments")
}

model Expense {
  id          String    @id @default(cuid())
  description String   @db.Text
  amount      Float     @default(0)
  category    String?
  dueDate     DateTime
  paidDate    DateTime?
  status      String    @default("PENDING")
  paymentMethod String?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("expenses")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  type        String    @default("CLASS")
  classId     String?
  startDate   DateTime
  endDate     DateTime
  allDay      Boolean   @default(false)
  location    String?
  color       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  class       Class?    @relation(fields: [classId], references: [id])

  @@map("events")
}

model Communication {
  id              String             @id @default(cuid())
  type            String             // EMAIL, SMS, WHATSAPP, NOTIFICATION, BULLETIN
  subject         String
  content         String   @db.Text
  recipients      String   @db.Text    // JSON array of recipient IDs
  recipientType   String             // ALL_STUDENTS, ALL_PARENTS, SPECIFIC_STUDENTS, ALL_TEACHERS, CLASS
  classId         String?
  scheduledFor    DateTime?
  sentById        String
  sentAt          DateTime?
  status          String             @default("SENT") // SENT, SCHEDULED, DRAFT
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  sentBy          User               @relation("sentCommunications", fields: [sentById], references: [id])

  @@map("communications")
}

model Message {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  senderId    String
  recipientId String?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  sender      User     @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model Document {
  id            String       @id @default(cuid())
  title         String
  type          String       // CONTRACT, FORM, REPORT, CERTIFICATE, OTHER
  category      String?
  description   String?  @db.Text
  fileUrl       String?   @db.Text
  studentId     String?
  enrollmentId  String?
  tags          String?   @db.Text      // JSON array
  archived      Boolean      @default(false)
  uploadedById  String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  student       Student?     @relation(fields: [studentId], references: [id])
  uploadedBy    User         @relation("uploadedDocuments", fields: [uploadedById], references: [id])

  @@map("documents")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String   // CREATE, UPDATE, DELETE
  entity      String   // Student, Teacher, Course, etc.
  entityId    String?
  description String?   @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Settings {
  id                      String   @id @default(cuid())
  schoolName              String   @default("Escola de Teatro")
  schoolAddress           String?   @db.Text
  schoolPhone             String?
  schoolEmail             String?
  schoolCnpj              String?
  defaultMonthlyFee       Float?
  lateFeePercent          Float?
  maxStudentsPerClass     Int?
  allowOnlineRegistration Boolean  @default(false)
  enableSmsNotifications  Boolean  @default(false)
  enableEmailNotifications Boolean @default(true)
  workingDays             String?   @db.Text  // JSON array
  academicYear            String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("settings")
}
